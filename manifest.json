{
  "manifest_version": 3,
  "name": "FB Keyword Finder",
  "version": "3.0.0",
  "description": "Find posts with keywords on Facebook",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://facebook.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FB Keyword Finder"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}