{
  "manifest_version": 3,
  "name": "Facebook Post Finder & Exporter",
  "version": "4.0.0",
  "description": "Find and export Facebook posts to CSV, Excel & JSON",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://facebook.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Facebook Post Finder & Exporter"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}