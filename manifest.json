{
  "manifest_version": 3,
  "name": "FB Post Scraper & Exporter",
  "version": "4.0.0",
  "description": "Scrape Facebook posts and export to CSV, Excel & JSON",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://facebook.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FB Post Scraper"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}